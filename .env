# spec_regen pipeline configuration
# Edit these paths to match your local environment.

# Input directories
IMAGES_DIR=docs/ci_repo
RAW_OCR_DIR=iris_ocr/CM_Spec_OCR_and_figtab_output/raw_data_advanced
TABLE_JSONS_DIR=iris_ocr/CM_Spec_OCR_and_figtab_output/table_jsons

# Output directories
YOLO_EXPORTS_DIR=yolo_exports
RESULTS_DIR=results_simple

# LLM provider: "ollama" or "mission_assist"
LLM_PROVIDER=ollama
LLM_MODEL=gemma3:27b
LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=

# YOLO settings
YOLO_CONFIDENCE=0.25
YOLO_DEVICE=cpu
