# Output directories
YOLO_EXPORTS_DIR=yolo_exports
RESULTS_DIR=results_simple

# LLM provider: "ollama", "mission_assist", "transformers", or "llama_server"
LLM_PROVIDER=llama_server
# `LLM_MODEL` is informational for llama_server (the server loads whatever
# GGUF it was launched with) but is still sent in the request body.
LLM_MODEL=gemma-3-12b-it
LLM_BASE_URL=http://localhost:8080
# LLM_API_KEY=  # not required for llama-server

