# =============================================================================
# spec_regen configuration
# =============================================================================

# --- Input directories ---
IMAGES_DIR=docs/ci_repo
RAW_OCR_DIR=iris_ocr/advanced/jsons
TABLE_JSONS_DIR=iris_ocr/CM_Spec_OCR_and_figtab_output/table_jsons

# --- Output directories ---
YOLO_EXPORTS_DIR=yolo_exports
RESULTS_DIR=results_simple

# =============================================================================
# LLM — ONE config drives every step (classify, title, and table OCR).
# Swap providers by changing LLM_PROVIDER; the steps select text vs. vision
# automatically. Options: mission_assist | llama_server | ollama | transformers
# =============================================================================
LLM_PROVIDER=mission_assist
LLM_MODEL=/genai/Gemma-4-31B-IT
LLM_BASE_URL=https://devmissionassist.api.us.baesystems.com
LLM_URL_SEGMENT=bae-api-gemma-4-31B
# Secrets/paths — set here or export in your shell (MA_API_KEY/MA_CA_CERT also work):
# LLM_API_KEY=
# LLM_CA_CERT=C:\spec_regen\CA03_Base64_FullRootChain.pem
LLM_MAX_IMAGE_SIDE=2048
LLM_TIMEOUT=180

# Table reconstruction: "llm" (vision OCR of crops) or "iris" (IRIS deliverable)
TABLE_MODE=llm

# --- Provider swap examples (uncomment one block, comment out Mission Assist) ---
# llama-server (local llama.cpp; LLM_MODEL is informational):
# LLM_PROVIDER=llama_server
# LLM_MODEL=gemma-3-12b-it
# LLM_BASE_URL=http://localhost:8080
#
# Ollama:
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:12b
# LLM_BASE_URL=http://localhost:11434
#
# Local transformers (LLM_BASE_URL is the model directory; no vision):
# LLM_PROVIDER=transformers
# LLM_MODEL=gemma-4-E4B-it
# LLM_BASE_URL=D:/transformers_cache/gemma-4-E4B-it

# --- YOLO settings ---
YOLO_CONFIDENCE=0.25
YOLO_DEVICE=cpu
