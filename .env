# spec_regen pipeline configuration
# Edit these paths to match your local environment.

# Input directories
IMAGES_DIR=docs/ci_repo
# RAW_OCR_DIR=iris_ocr/CM_Spec_OCR_and_figtab_output/raw_data_advanced
